{
  "name": "ozbys-node-pubsub",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean",
    "dev": "turbo run dev",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}\"",
    "lint": "turbo run lint",
    "lint:repo": "oxlint .",
    "test": "turbo run test",
    "check-types": "turbo run check-types",
    "commitlint": "commitlint",
    "secretlint": "secretlint",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@secretlint/secretlint-rule-preset-recommend": "^9.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "oxlint": "^1.61.0",
    "prettier": "^3.8.3",
    "secretlint": "^9.3.0",
    "turbo": "^2.4.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "oxlint --quiet",
      "prettier --check"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --check"
    ]
  },
  "packageManager": "pnpm@9.15.2",
  "engines": {
    "node": ">=18"
  }
}
