{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Payload Mapper Eval Contract",
  "version": "v1",
  "description": "Executable contract for the integration payload mapper eval harness. Future mapper implementations must satisfy this contract.",
  "input_format": {
    "description": "Mapper input: source payload + target field list",
    "schema": {
      "type": "object",
      "required": [
        "source_system",
        "source_model",
        "target_model",
        "target_contract_version",
        "source_payload",
        "target_fields"
      ],
      "properties": {
        "source_system": { "type": "string" },
        "source_model": { "type": "string" },
        "target_model": { "type": "string" },
        "target_contract_version": { "type": "string" },
        "source_payload": { "type": "object" },
        "target_fields": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "output_format": {
    "description": "Mapper output: structured suggestion batch persisted by the deterministic intake adapter",
    "schema": {
      "type": "object",
      "required": [
        "mapping_trace_id",
        "contract_id",
        "contract_version",
        "source_system",
        "prompt_version",
        "generated_at",
        "overall_confidence",
        "missing_required_fields",
        "ambiguous_target_fields",
        "suggestions",
        "summary"
      ],
      "properties": {
        "mapping_trace_id": { "type": "string" },
        "contract_id": { "type": "string" },
        "contract_version": { "type": "string" },
        "source_system": { "type": "string" },
        "prompt_version": {
          "type": "string",
          "description": "Persisted prompt contract version for eval/debug traceability."
        },
        "generated_at": { "type": "string" },
        "overall_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "drift_categories": {
          "type": "array",
          "items": { "type": "string" }
        },
        "missing_required_fields": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Target fields that cannot be populated from the source payload"
        },
        "ambiguous_target_fields": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Fields where the mapping is uncertain or requires operator review"
        },
        "suggestions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "source_path",
              "target_field",
              "transform_kind",
              "confidence",
              "deterministic_validation",
              "review_status",
              "replay_status"
            ],
            "properties": {
              "id": { "type": "string" },
              "source_path": { "type": "string" },
              "target_field": { "type": "string" },
              "transform_kind": { "type": "string" },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
              "explanation": { "type": "string" },
              "evidence_sample": { "type": "string" },
              "deterministic_validation": {
                "type": "object",
                "required": ["is_valid", "validated_at", "errors"],
                "properties": {
                  "is_valid": { "type": "boolean" },
                  "validated_at": { "type": "string" },
                  "errors": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              },
              "review_status": { "type": "string" },
              "replay_status": { "type": "string" }
            }
          }
        },
        "summary": { "type": "string" }
      }
    }
  },
  "scoring_rules": {
    "exact_match": {
      "description": "Project suggestions into target_field -> source_path pairs and compare them to gold expected_mapping values",
      "method": "normalized_target_field_source_path_equality",
      "weight": 0.4
    },
    "missing_field_detection": {
      "description": "Compare missing_required_fields to gold missing_fields using set operations",
      "method": "set_recall_and_precision",
      "weight": 0.2
    },
    "ambiguity_detection": {
      "description": "Compare ambiguous_target_fields to gold ambiguous_fields using set operations",
      "method": "set_recall_and_precision",
      "weight": 0.2
    },
    "non_hallucination": {
      "description": "Verify every suggested source_path exists in the source_payload after normalizing eval-task path syntax to deterministic pointer syntax",
      "method": "path_existence_check",
      "weight": 0.15,
      "hard_gate": true
    },
    "correct_abstention": {
      "description": "On adversarial tasks with expected_mapping={}, mapper should return minimal or empty suggested_mapping",
      "method": "empty_mapping_check",
      "weight": 0.05
    }
  },
  "pass_thresholds": {
    "eval_weighted_score": 0.75,
    "adversarial_weighted_score": 0.6,
    "non_hallucination_hard_gate": 0.75
  },
  "non_goals": [
    "Autonomous mutation of production delivery payloads",
    "Fine-tuning or training a custom model",
    "Full HRIS/payroll dataset coverage across many vendors",
    "Free-form text generation or summarization"
  ]
}
