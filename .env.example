# Documentation-only example for local development.
# Prefer `doppler run --config <env> -- <command>` for steady-state commands.
# Cloudflare bindings such as HYPERDRIVE, DELIVERY_QUEUE, RATE_LIMITER,
# ANALYTICS, and TOPIC_ROOMS come from wrangler/Cloudflare, not this file.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pubsub
JWT_SECRET=replace-me-for-local-only
API_URL=http://127.0.0.1:8787
CLIENT_PORT=3000
NODE_ENV=development
