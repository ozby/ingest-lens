{
  "name": "@repo/ui",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "files": [
    "dist/**",
    "dist"
  ],
  "sideEffects": false,
  "exports": {
    "./components": {
      "import": {
        "types": "./dist/es/components.d.mts",
        "default": "./dist/es/components.mjs"
      },
      "require": {
        "types": "./dist/cjs/components.d.ts",
        "default": "./dist/cjs/components.js"
      }
    },
    "./lib": {
      "import": {
        "types": "./dist/es/lib.d.mts",
        "default": "./dist/es/lib.mjs"
      },
      "require": {
        "types": "./dist/cjs/lib.d.ts",
        "default": "./dist/cjs/lib.js"
      }
    }
  },
  "scripts": {
    "build": "bunchee",
    "dev": "bunchee --watch",
    "check-types": "tsgo --noEmit",
    "lint": "oxlint src/",
    "test": "vitest run"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "catalog:",
    "@radix-ui/react-dialog": "catalog:",
    "@radix-ui/react-dropdown-menu": "catalog:",
    "@radix-ui/react-label": "catalog:",
    "@radix-ui/react-select": "catalog:",
    "@radix-ui/react-slot": "catalog:",
    "@radix-ui/react-tabs": "catalog:",
    "@radix-ui/react-toast": "catalog:",
    "@radix-ui/react-tooltip": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "lucide-react": "catalog:",
    "next-themes": "catalog:",
    "react-hook-form": "catalog:",
    "sonner": "catalog:",
    "tailwind-merge": "catalog:",
    "tailwindcss": "catalog:",
    "tailwindcss-animate": "catalog:"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:tooling",
    "bunchee": "catalog:",
    "vitest": "catalog:tooling"
  },
  "peerDependencies": {
    "@types/react": ">=18",
    "@types/react-dom": ">=18",
    "react": ">=18",
    "react-dom": ">=18"
  }
}
