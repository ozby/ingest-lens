{
  "name": "api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsup --watch --onSuccess \"node dist/index.cjs\"",
    "build": "tsup",
    "check-types": "tsgo --noEmit",
    "lint": "oxlint src/",
    "test": "vitest run",
    "mutation": "stryker run",
    "perf:test": "artillery run artillery.yml",
    "perf:test:report": "artillery report artillery-report.json",
    "perf:clinic": "clinic doctor -- node dist/index.cjs",
    "perf:clinic:flame": "clinic flame -- node dist/index.cjs",
    "perf:clinic:bubbleprof": "clinic bubbleprof -- node dist/index.cjs"
  },
  "dependencies": {
    "@repo/logger": "workspace:*",
    "@repo/types": "workspace:*",
    "axios": "catalog:",
    "body-parser": "^1.20.3",
    "cors": "catalog:",
    "express": "catalog:",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "catalog:",
    "jsonwebtoken": "catalog:",
    "mongodb-memory-server": "catalog:",
    "mongoose": "catalog:",
    "morgan": "catalog:",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.8.1",
    "uuid": "catalog:",
    "winston": "catalog:"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@stryker-mutator/core": "catalog:",
    "@stryker-mutator/typescript-checker": "catalog:",
    "@stryker-mutator/vitest-runner": "catalog:",
    "@types/autocannon": "^7.12.6",
    "@types/axios": "catalog:",
    "@types/body-parser": "^1.19.5",
    "@types/cors": "catalog:",
    "@types/express": "catalog:",
    "@types/jsonwebtoken": "catalog:",
    "@types/mongoose": "catalog:",
    "@types/morgan": "catalog:",
    "@types/node": "catalog:",
    "@types/socket.io-client": "^1.4.36",
    "@types/supertest": "catalog:",
    "@types/uuid": "^9.0.7",
    "@typescript/native-preview": "catalog:tooling",
    "artillery": "^2.0.0-41",
    "autocannon": "^7.12.0",
    "clinic": "^12.0.0",
    "supertest": "catalog:",
    "ts-node": "catalog:",
    "tsup": "catalog:",
    "vitest": "catalog:tooling"
  }
}
